extends default

block content
    script.
        document.addEventListener('DOMContentLoaded', function() {
            // Intersection-observer scroll animations
            const io = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        entry.target.classList.remove('rk-hidden');
                        entry.target.classList.add('rk-visible');
                        io.unobserve(entry.target);
                    }
                });
            }, { threshold: 0.08 });
            document.querySelectorAll('[data-rk-animate]').forEach(el => {
                el.classList.add('rk-hidden');
                io.observe(el);
            });

            // Earnings chart
            const chartCanvas = document.getElementById('earningsChart');
            if (chartCanvas && window.Chart) {
                const ctx = chartCanvas.getContext('2d');
                new Chart(ctx, {
                    type: 'line',
                    data: {
                        labels: ['1ヶ月目', '2ヶ月目', '3ヶ月目', '4ヶ月目', '5ヶ月目', '6ヶ月目'],
                        datasets: [{
                            label: '推定収益（円）',
                            data: [5000, 9000, 14000, 20000, 25000, 30000],
                            borderColor: '#8b5cf6',
                            backgroundColor: 'rgba(139, 92, 246, 0.15)',
                            tension: 0.4,
                            fill: true,
                            pointRadius: 5,
                            pointBackgroundColor: '#7c3aed',
                            pointBorderColor: '#fff',
                            pointBorderWidth: 2
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: { display: false },
                            tooltip: {
                                backgroundColor: 'rgba(15,23,42,0.95)',
                                borderColor: 'rgba(139,92,246,0.3)',
                                borderWidth: 1,
                                titleColor: '#94a3b8',
                                bodyColor: '#f1f5f9',
                                callbacks: { label: (ctx) => ` ${ctx.parsed.y.toLocaleString()}円` }
                            }
                        },
                        scales: {
                            x: { ticks: { color: '#64748b' }, grid: { color: 'rgba(51,65,85,0.4)' } },
                            y: {
                                ticks: { color: '#64748b', callback: (v) => `${v.toLocaleString()}円` },
                                grid: { color: 'rgba(51,65,85,0.4)' }
                            }
                        }
                    }
                });
            }
        });

    script(src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js")

    style.
        /* ── Reset & base ──────────────────────────────────────── */
        body { background: #0f172a; color: #f1f5f9; font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; }

        /* ── Scroll animations ─────────────────────────────────── */
        .rk-hidden  { opacity: 0; transform: translateY(24px); transition: opacity .6s ease, transform .6s ease; }
        .rk-visible { opacity: 1; transform: translateY(0); }

        /* ── Shared helpers ────────────────────────────────────── */
        .rk-gradient-text {
            background: linear-gradient(135deg, #a78bfa 0%, #8b5cf6 50%, #c084fc 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }
        .rk-glass {
            background: rgba(30,41,59,.75);
            backdrop-filter: blur(14px);
            -webkit-backdrop-filter: blur(14px);
            border: 1px solid rgba(51,65,85,.55);
            border-radius: 16px;
        }
        .rk-btn-primary {
            display: inline-flex; align-items: center; justify-content: center; gap: 8px;
            background: linear-gradient(135deg, #7c3aed, #9333ea);
            color: #fff; font-weight: 700; font-size: 1rem;
            padding: 14px 34px; border-radius: 50px; border: none;
            box-shadow: 0 8px 24px rgba(124,58,237,.35);
            text-decoration: none; cursor: pointer;
            transition: transform .25s, box-shadow .25s, filter .25s;
        }
        .rk-btn-primary:hover { transform: translateY(-3px); box-shadow: 0 14px 30px rgba(124,58,237,.5); filter: brightness(1.1); color: #fff; text-decoration: none; }
        .rk-btn-outline {
            display: inline-flex; align-items: center; justify-content: center; gap: 8px;
            background: transparent; color: #cbd5e1; font-weight: 700; font-size: 1rem;
            padding: 13px 34px; border-radius: 50px; border: 1.5px solid rgba(148,163,184,.35);
            text-decoration: none; cursor: pointer;
            transition: border-color .25s, color .25s, background .25s;
        }
        .rk-btn-outline:hover { border-color: #8b5cf6; color: #fff; background: rgba(139,92,246,.1); text-decoration: none; }
        .rk-section { padding: 90px 0; }
        .rk-section-alt { background: rgba(15,23,42,1); }
        .rk-section-tinted { background: rgba(30,41,59,.4); }
        .rk-section-title { font-size: 2.4rem; font-weight: 800; color: #fff; line-height: 1.2; margin-bottom: 14px; }
        .rk-section-sub { font-size: 1.1rem; color: #94a3b8; margin-bottom: 50px; }
        @media (max-width: 768px) { .rk-section-title { font-size: 1.8rem; } .rk-section { padding: 60px 0; } }

        /* ── Top-nav override ──────────────────────────────────── */
        .top-nav { background: rgba(15,23,42,.9) !important; backdrop-filter: blur(12px); border-bottom: 1px solid rgba(51,65,85,.5) !important; }
        .top-nav .navbar { background: transparent !important; }
        .top-nav .navbar-brand { color: #f1f5f9 !important; font-weight: 800; font-size: 1.3rem; }
        .top-nav .navbar-brand:hover { color: #a78bfa !important; }
        .rk-nav-login {
            color: #cbd5e1 !important; font-weight: 600;
            border: 1.5px solid rgba(148,163,184,.3) !important;
            border-radius: 50px !important; padding: 7px 22px !important;
            transition: border-color .2s, color .2s, background .2s !important;
            text-decoration: none !important; background: transparent !important;
        }
        .rk-nav-login:hover { border-color: #8b5cf6 !important; color: #a78bfa !important; background: rgba(139,92,246,.1) !important; }

        /* ── Hero ──────────────────────────────────────────────── */
        #rk-hero {
            min-height: 92vh; display: flex; align-items: center;
            position: relative; overflow: hidden;
            background: radial-gradient(ellipse 80% 60% at 50% -10%, rgba(124,58,237,.25) 0%, transparent 70%),
                        radial-gradient(ellipse 50% 40% at 80% 80%, rgba(147,51,234,.12) 0%, transparent 60%),
                        #0f172a;
        }
        #rk-hero .rk-hero-badge {
            display: inline-flex; align-items: center; gap: 8px;
            background: rgba(139,92,246,.15); border: 1px solid rgba(139,92,246,.3);
            color: #c4b5fd; font-size: .85rem; font-weight: 600;
            padding: 6px 16px; border-radius: 50px; margin-bottom: 22px;
        }
        #rk-hero h1 { font-size: 3.4rem; font-weight: 800; line-height: 1.15; color: #fff; }
        #rk-hero p.rk-hero-sub { font-size: 1.2rem; color: #94a3b8; line-height: 1.75; margin: 18px 0 32px; }
        #rk-hero .rk-hero-pills { display: flex; flex-direction: column; gap: 12px; margin-bottom: 28px; max-width: 440px; }
        #rk-hero .rk-hero-pill {
            background: rgba(30,41,59,.7); border: 1px solid rgba(51,65,85,.6);
            border-radius: 12px; padding: 14px 20px; color: #e2e8f0; font-weight: 600;
            display: flex; align-items: center; gap: 10px;
        }
        #rk-hero .rk-hero-pill i { color: #8b5cf6; }
        .rk-hero-visual {
            background: rgba(30,41,59,.6); border: 1px solid rgba(51,65,85,.5);
            border-radius: 24px; padding: 28px; box-shadow: 0 30px 60px rgba(0,0,0,.4);
        }
        .rk-hero-visual img { border-radius: 14px; width: 100%; height: auto; display: block; }
        @media (max-width: 991px) { #rk-hero { min-height: auto; padding: 80px 0 60px; } #rk-hero h1 { font-size: 2.4rem; } }

        /* ── Stat cards ────────────────────────────────────────── */
        .rk-stat-card {
            padding: 24px; position: relative; overflow: hidden;
            transition: transform .3s, box-shadow .3s;
        }
        .rk-stat-card:hover { transform: translateY(-4px); box-shadow: 0 16px 40px rgba(0,0,0,.3); }
        .rk-stat-card .rk-stat-icon {
            width: 48px; height: 48px; border-radius: 14px;
            display: flex; align-items: center; justify-content: center;
            font-size: 1.3rem; margin-bottom: 16px;
        }
        .rk-stat-card .rk-stat-val { font-size: 1.9rem; font-weight: 800; color: #fff; }
        .rk-stat-card .rk-stat-label { font-size: .9rem; color: #94a3b8; margin-top: 4px; }

        /* ── Feature cards ─────────────────────────────────────── */
        .rk-feature-card {
            padding: 28px; height: 100%;
            transition: transform .3s, box-shadow .3s, border-color .3s;
        }
        .rk-feature-card:hover { transform: translateY(-5px); box-shadow: 0 20px 40px rgba(0,0,0,.3); border-color: rgba(139,92,246,.35) !important; }
        .rk-feature-icon {
            width: 52px; height: 52px; border-radius: 14px;
            background: rgba(139,92,246,.15); color: #a78bfa;
            display: flex; align-items: center; justify-content: center;
            font-size: 1.4rem; margin-bottom: 18px;
        }
        .rk-feature-card h4 { font-weight: 700; color: #f1f5f9; font-size: 1.05rem; margin-bottom: 10px; }
        .rk-feature-card p { color: #64748b; font-size: .95rem; line-height: 1.7; margin: 0; }

        /* ── Step cards ────────────────────────────────────────── */
        .rk-step-num {
            width: 56px; height: 56px; border-radius: 50%;
            background: linear-gradient(135deg, #7c3aed, #9333ea);
            display: flex; align-items: center; justify-content: center;
            font-size: 1.4rem; font-weight: 800; color: #fff;
            margin: 0 auto 18px; box-shadow: 0 8px 20px rgba(124,58,237,.35);
        }
        .rk-step-card { text-align: center; padding: 32px 20px; }
        .rk-step-card h5 { color: #f1f5f9; font-weight: 700; margin-bottom: 10px; }
        .rk-step-card p { color: #64748b; font-size: .95rem; margin: 0; }

        /* ── Benefits ──────────────────────────────────────────── */
        .rk-benefit-item { display: flex; align-items: flex-start; gap: 16px; padding: 18px 0; }
        .rk-benefit-icon { width: 40px; height: 40px; min-width: 40px; border-radius: 10px; background: rgba(139,92,246,.15); color: #a78bfa; display: flex; align-items: center; justify-content: center; font-size: 1.1rem; }
        .rk-benefit-item h5 { color: #e2e8f0; font-weight: 700; font-size: 1rem; margin-bottom: 4px; }
        .rk-benefit-item p { color: #64748b; font-size: .9rem; margin: 0; }

        /* ── CTA band ──────────────────────────────────────────── */
        .rk-cta {
            background: radial-gradient(ellipse 80% 70% at 50% 50%, rgba(124,58,237,.22) 0%, transparent 70%), #0f172a;
            border-top: 1px solid rgba(51,65,85,.4);
            border-bottom: 1px solid rgba(51,65,85,.4);
            padding: 90px 0;
        }

        /* ── Dashboard preview card ────────────────────────────── */
        .rk-dash-preview { padding: 28px; }
        .rk-chart-wrap { height: 280px; }
        .rk-stat-row { display: grid; grid-template-columns: repeat(4,1fr); gap: 12px; margin-bottom: 20px; }
        @media (max-width: 768px) { .rk-stat-row { grid-template-columns: repeat(2,1fr); } }
        .rk-mini-stat { background: rgba(15,23,42,.6); border: 1px solid rgba(51,65,85,.4); border-radius: 12px; padding: 14px 16px; }
        .rk-mini-stat .val { font-size: 1.3rem; font-weight: 800; color: #fff; }
        .rk-mini-stat .lbl { font-size: .75rem; color: #64748b; margin-top: 2px; }

        /* ── FAQ ───────────────────────────────────────────────── */
        .rk-faq .accordion-item { background: rgba(30,41,59,.6); border: 1px solid rgba(51,65,85,.5) !important; border-radius: 12px !important; overflow: hidden; margin-bottom: 10px; }
        .rk-faq .accordion-button { background: rgba(30,41,59,.6) !important; color: #e2e8f0 !important; font-weight: 600; }
        .rk-faq .accordion-button:not(.collapsed) { background: rgba(139,92,246,.1) !important; color: #c4b5fd !important; box-shadow: none !important; }
        .rk-faq .accordion-button::after { filter: invert(1) brightness(.6); }
        .rk-faq .accordion-body { background: rgba(15,23,42,.5); color: #94a3b8; border-top: 1px solid rgba(51,65,85,.4); }

        /* ── Footer ────────────────────────────────────────────── */
        .rk-footer { background: rgba(15,23,42,1); border-top: 1px solid rgba(51,65,85,.4); padding: 32px 0; text-align: center; color: #475569; font-size: .9rem; }
        .rk-footer a { color: #64748b; text-decoration: none; }
        .rk-footer a:hover { color: #a78bfa; }

        /* ── Login modal  ──────────────────────────────────────── */
        #rk-login-modal {
            display: none; position: fixed; inset: 0; z-index: 9999;
            background: rgba(0,0,0,.7); backdrop-filter: blur(6px);
            align-items: center; justify-content: center;
        }
        #rk-login-modal.show { display: flex; }
        .rk-modal-box {
            width: 100%; max-width: 420px; margin: 16px;
            background: #1e293b; border: 1px solid rgba(51,65,85,.7);
            border-radius: 22px; padding: 40px 36px; position: relative;
            box-shadow: 0 40px 80px rgba(0,0,0,.6);
        }
        .rk-modal-close { position: absolute; top: 16px; right: 16px; background: none; border: none; color: #475569; font-size: 1.3rem; cursor: pointer; transition: color .2s; }
        .rk-modal-close:hover { color: #f1f5f9; }
        .rk-google-btn {
            display: flex; align-items: center; justify-content: center; gap: 10px;
            width: 100%; padding: 13px; border-radius: 14px;
            border: 1px solid rgba(51,65,85,.6); background: rgba(51,65,85,.3);
            color: #e2e8f0; font-weight: 600; font-size: .95rem;
            text-decoration: none; transition: background .2s, border-color .2s;
        }
        .rk-google-btn:hover { background: rgba(51,65,85,.6); border-color: rgba(139,92,246,.4); color: #fff; text-decoration: none; }
        .rk-divider { display: flex; align-items: center; gap: 12px; margin: 20px 0; color: #475569; font-size: .85rem; }
        .rk-divider::before, .rk-divider::after { content: ''; flex: 1; height: 1px; background: rgba(51,65,85,.5); }

    //- ── Login modal ──────────────────────────────────────
    #rk-login-modal(onclick="if(event.target===this)rkHideLogin()")
        .rk-modal-box
            button.rk-modal-close(onclick="rkHideLogin()" aria-label="閉じる")
                i.bi.bi-x-lg
            .text-center.mb-4
                div(style="width:60px;height:60px;border-radius:16px;background:linear-gradient(135deg,#7c3aed,#9333ea);display:flex;align-items:center;justify-content:center;margin:0 auto 14px;")
                    i.bi.bi-magic(style="font-size:1.6rem;color:#fff;")
                h2(style="font-size:1.5rem;font-weight:800;color:#f1f5f9;margin:0;") Rakuado
                p(style="color:#64748b;font-size:.9rem;margin-top:4px;") ダッシュボードにログイン
            a.rk-google-btn(href='/auth/google')
                img(src='/img/googleauth.svg' alt='Google' style="height:22px;")
                | Googleで続ける
            .rk-divider または
            form#rk-email-form.d-none(onsubmit="rkEmailLogin(event)")
                div(style="margin-bottom:12px;")
                    label(for='rk-email' style="display:block;font-size:.85rem;font-weight:600;color:#94a3b8;margin-bottom:6px;") メールアドレス
                    input#rk-email(type='email' name='email' required placeholder='you@example.com'
                        style="width:100%;padding:11px 16px;border-radius:12px;border:1px solid rgba(51,65,85,.6);background:rgba(15,23,42,.6);color:#f1f5f9;font-size:.95rem;outline:none;")
                button.rk-btn-primary(type='submit' style="width:100%;border-radius:12px;justify-content:center;")
                    i.bi.bi-send
                    | ログインリンクを送る
            #rk-email-sent.d-none(style="text-align:center;padding:16px;background:rgba(139,92,246,.1);border:1px solid rgba(139,92,246,.25);border-radius:12px;")
                i.bi.bi-envelope-check(style="font-size:2rem;color:#a78bfa;display:block;margin-bottom:8px;")
                p(style="color:#c4b5fd;font-weight:600;margin:0;") メールを確認してください
                a#rk-resend(href='#' onclick="rkResendEmail(event)" style="display:block;margin-top:8px;font-size:.85rem;color:#64748b;") 再送する
            p(style="text-align:center;font-size:.78rem;color:#475569;margin-top:20px;margin-bottom:0;")
                | 続行することで、
                a(href='/contact' style="color:#64748b;") 利用規約
                |  および 
                a(href='/contact' style="color:#64748b;") プライバシーポリシー
                | に同意します。

    script.
        function rkShowLogin() {
            document.getElementById('rk-login-modal').classList.add('show');
            document.body.style.overflow = 'hidden';
        }
        function rkHideLogin() {
            document.getElementById('rk-login-modal').classList.remove('show');
            document.body.style.overflow = '';
        }
        function rkEmailLogin(e) {
            e.preventDefault();
            const email = document.getElementById('rk-email').value;
            fetch('/auth/magic', {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify({ email })
            }).then(r => r.json()).then(() => {
                document.getElementById('rk-email-form').classList.add('d-none');
                document.getElementById('rk-email-sent').classList.remove('d-none');
            }).catch(() => alert('エラーが発生しました'));
        }
        function rkResendEmail(e) {
            e.preventDefault();
            document.getElementById('rk-email-form').classList.remove('d-none');
            document.getElementById('rk-email-sent').classList.add('d-none');
        }

    //- ── HERO ─────────────────────────────────────────────
    section#rk-hero
        .container
            .row.align-items-center.g-5
                .col-12.col-lg-6
                    .rk-hero-badge(data-rk-animate)
                        i.bi.bi-stars
                        | 収益化パートナー募集中
                    h1(data-rk-animate)
                        | 安定収入で<br>
                        span.rk-gradient-text ブログ収益を最大化
                    p.rk-hero-sub(data-rk-animate) クリックに頼らない、毎月固定の広告収益。<br>シンプルな設定で今日から始められます。
                    .rk-hero-pills(data-rk-animate)
                        .rk-hero-pill
                            i.bi.bi-graph-up-arrow
                            | Google AdSenseより高い固定報酬を実現
                        .rk-hero-pill
                            i.bi.bi-cash-coin
                            | 最低 5,000円〜 実績では月30,000円以上も可能
                        .rk-hero-pill
                            i.bi.bi-wordpress
                            | WordPress対応 • 日本語サポート付き
                    .d-flex.flex-wrap.gap-3(data-rk-animate)
                        a.rk-btn-primary(href="/partner-recruitment")
                            i.bi.bi-rocket-takeoff
                            | 無料見積もりを依頼
                        button.rk-btn-outline(onclick="rkShowLogin()")
                            i.bi.bi-box-arrow-in-right
                            | ログイン
                .col-12.col-lg-6(data-rk-animate)
                    .rk-hero-visual
                        img(src="/img/top-img.gif" alt="Rakuado ダッシュボード")

    //- ── STATS BAND ───────────────────────────────────────
    section.rk-section.rk-section-tinted(style="padding:50px 0;")
        .container
            .row.g-4.text-center
                .col-6.col-md-3(data-rk-animate)
                    .rk-glass.rk-stat-card
                        .rk-stat-icon.mx-auto(style="background:rgba(139,92,246,.15);color:#a78bfa;")
                            i.bi.bi-people-fill
                        .rk-stat-val 500+
                        .rk-stat-label パートナーブログ数
                .col-6.col-md-3(data-rk-animate)
                    .rk-glass.rk-stat-card
                        .rk-stat-icon.mx-auto(style="background:rgba(16,185,129,.15);color:#34d399;")
                            i.bi.bi-cash-stack
                        .rk-stat-val 30,000円
                        .rk-stat-label 月間最高収益実績
                .col-6.col-md-3(data-rk-animate)
                    .rk-glass.rk-stat-card
                        .rk-stat-icon.mx-auto(style="background:rgba(245,158,11,.15);color:#fbbf24;")
                            i.bi.bi-lightning-charge-fill
                        .rk-stat-val 3ステップ
                        .rk-stat-label 設定完了まで
                .col-6.col-md-3(data-rk-animate)
                    .rk-glass.rk-stat-card
                        .rk-stat-icon.mx-auto(style="background:rgba(59,130,246,.15);color:#60a5fa;")
                            i.bi.bi-headset
                        .rk-stat-val 24/7
                        .rk-stat-label 日本語サポート

    //- ── FEATURES ─────────────────────────────────────────
    section.rk-section
        .container
            .text-center.mb-5
                h2.rk-section-title(data-rk-animate)
                    | 主な
                    span.rk-gradient-text  機能
                p.rk-section-sub(data-rk-animate) ブロガーに最適化された機能で、収益化を簡単に
            .row.g-4
                .col-12.col-md-6.col-lg-4(data-rk-animate)
                    .rk-glass.rk-feature-card
                        .rk-feature-icon
                            i.bi.bi-bar-chart-line-fill
                        h4 充実したダッシュボード
                        p 収益状況、アクセス解析、パフォーマンス指標を一目で確認できる直感的なダッシュボード
                .col-12.col-md-6.col-lg-4(data-rk-animate)
                    .rk-glass.rk-feature-card
                        .rk-feature-icon
                            i.bi.bi-lightning-fill
                        h4 簡単な設定
                        p 複雑な設定は不要。わずか数ステップで広告を開始できます
                .col-12.col-md-6.col-lg-4(data-rk-animate)
                    .rk-glass.rk-feature-card
                        .rk-feature-icon
                            i.bi.bi-shield-check
                        h4 安全で確実
                        p 信頼性の高い広告配信システムで、安定した収益を実現
                .col-12.col-md-6.col-lg-4(data-rk-animate)
                    .rk-glass.rk-feature-card
                        .rk-feature-icon
                            i.bi.bi-phone
                        h4 モバイル対応
                        p スマートフォンやタブレットからも、いつでもどこでも管理可能
                .col-12.col-md-6.col-lg-4(data-rk-animate)
                    .rk-glass.rk-feature-card
                        .rk-feature-icon
                            i.bi.bi-headset
                        h4 サポート充実
                        p 専任サポートチームが、お客様の成功を全力でサポート
                .col-12.col-md-6.col-lg-4(data-rk-animate)
                    .rk-glass.rk-feature-card
                        .rk-feature-icon
                            i.bi.bi-arrow-repeat
