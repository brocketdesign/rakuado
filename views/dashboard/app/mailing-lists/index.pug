extends ../../base

block mainContent
  .container-fluid.px-4
    // Header
    .d-flex.justify-content-between.align-items-center.mb-4
      div
        h1.fw-bold
          i.fas.fa-envelope.me-2.text-primary
          | Mailing Lists
        p.text-muted.mb-0 Create mailing lists and collect emails from your forms.
      div
        button.btn.btn-primary#createListBtn
          i.fas.fa-plus.me-1
          | New Mailing List

    // Mailing Lists Grid
    #listsLoading.text-center.py-5
      .spinner-border.text-primary(role='status')
      p.text-muted.mt-2 Loading mailing lists...

    #listsEmpty.text-center.py-5(style="display:none")
      i.fas.fa-envelope-open-text.text-muted.display-4.mb-3
      p.text-muted.mb-2 No mailing lists yet
      p.text-muted.small Create your first mailing list to start collecting emails.

    #listsContainer.row.g-3(style="display:none")

    // Subscriber Detail Panel (hidden by default)
    #subscriberPanel(style="display:none")
      .d-flex.justify-content-between.align-items-center.mb-4
        div
          h2.fw-bold#panelListName
          p.text-muted.mb-0#panelListDesc
        div
          button.btn.btn-outline-secondary.me-2#backToListsBtn
            i.fas.fa-arrow-left.me-1
            | Back
          button.btn.btn-outline-primary.me-2#copyUrlBtn
            i.fas.fa-link.me-1
            | Copy Form URL
          button.btn.btn-outline-success#exportCsvBtn
            i.fas.fa-download.me-1
            | Export CSV

      // Form URL Card
      .card.border-0.shadow-sm.mb-4#formUrlCard
        .card-header.bg-white.border-0
          h5.fw-bold.mb-0
            i.fas.fa-code.me-2.text-success
            | Form Integration
        .card-body
          p.text-muted Use this URL as your form action to collect emails:
          .bg-dark.rounded.p-3.mb-3
            code.text-success#formUrlDisplay
          p.text-muted.mb-2 Example HTML form:
          .bg-dark.rounded.p-3
            pre.text-success.mb-0#formExampleCode

      // Domain Summary — clickable cards to filter by domain
      .card.border-0.shadow-sm.mb-4#domainSummaryCard(style="display:none")
        .card-header.bg-white.border-0.d-flex.justify-content-between.align-items-center
          h5.fw-bold.mb-0
            i.fas.fa-globe.me-2.text-info
            | Subscribers by Domain
          button.btn.btn-sm.btn-outline-secondary#clearDomainFilter(style="display:none")
            i.fas.fa-times.me-1
            | Show All
        .card-body
          .row.g-2#domainSummaryBody

      // Active domain filter indicator
      .alert.alert-info.d-flex.align-items-center.justify-content-between.mb-3#domainFilterAlert(style="display:none")
        div
          i.fas.fa-filter.me-2
          span#domainFilterText
        button.btn.btn-sm.btn-outline-info#clearDomainFilterAlert
          i.fas.fa-times.me-1
          | Clear

      // Filters
      .d-flex.align-items-center.flex-wrap.gap-3.mb-3
        div
          label.me-2.fw-bold Filter by tag:
          select.form-select.form-select-sm.d-inline-block#tagFilter(style="max-width:200px")
            option(value="") All tags
        div
          label.me-2.fw-bold Filter by domain:
          select.form-select.form-select-sm.d-inline-block#domainFilter(style="max-width:200px")
            option(value="") All domains
        div
          label.me-2.fw-bold Sort by:
          select.form-select.form-select-sm.d-inline-block#sortBy(style="max-width:200px")
            option(value="date-desc") Newest first
            option(value="date-asc") Oldest first
            option(value="email-asc") Email A→Z
            option(value="email-desc") Email Z→A
            option(value="domain-asc") Domain A→Z
            option(value="domain-desc") Domain Z→A
      
      // Subscribers Table
      .card.border-0.shadow-sm.mb-4
        .card-header.bg-white.border-0.d-flex.justify-content-between.align-items-center
          h5.fw-bold.mb-0
            i.fas.fa-users.me-2.text-secondary
            | Subscribers
            span.badge.bg-primary.ms-2#subscriberCount 0
        .card-body.p-0
          #subscribersLoading.text-center.py-5
            .spinner-border.text-primary(role='status')
          #subscribersEmpty.text-center.py-4(style="display:none")
            p.text-muted No subscribers yet. Share your form URL to start collecting emails.
          .table-responsive
            table#subscribersTable.table.table-hover.mb-0(style="display:none")
              thead.table-light
                tr
                  th Email
                  th(style="cursor:pointer")#sortDomainHeader
                    | Domain
                    i.fas.fa-sort.ms-1.text-muted
                  th Tags
                  th Subscribed
                  th.text-end Actions
              tbody#subscribersBody

    // Create / Edit Modal
    .modal.fade#listModal(tabindex="-1")
      .modal-dialog
        .modal-content
          .modal-header
            h5.modal-title#listModalTitle Create Mailing List
            button.btn-close(type="button" data-bs-dismiss="modal")
          .modal-body
            form#listForm
              .mb-3
                label.form-label.fw-bold(for="listName") Name *
                input.form-control#listName(type="text" placeholder="e.g. Newsletter, Beta Users..." required)
              .mb-3
                label.form-label.fw-bold(for="listDescription") Description
                textarea.form-control#listDescription(rows="2" placeholder="Optional description...")
          .modal-footer
            button.btn.btn-secondary(type="button" data-bs-dismiss="modal") Cancel
            button.btn.btn-primary#saveListBtn
              i.fas.fa-save.me-1
              | Save

  script(src="/js/mailing-lists.js")
