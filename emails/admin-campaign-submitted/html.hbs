<!DOCTYPE html PUBLIC "-//W3C//DTD XHTML 1.0 Transitional//EN" "http://www.w3.org/TR/xhtml1/DTD/xhtml1-transitional.dtd">
<html xmlns="http://www.w3.org/1999/xhtml">
<head>
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta http-equiv="Content-Type" content="text/html; charset=UTF-8" />
  <title>Campaign Submitted for Review</title>
</head>
<body style="-webkit-text-size-adjust:none;color:#74787e;font-family:Arial,'Helvetica Neue',Helvetica,sans-serif;height:100%;line-height:1.4;margin:0;width:100%!important;" bgcolor="#f2f4f6">
  <table width="100%" cellpadding="0" cellspacing="0" bgcolor="#f2f4f6" style="font-family:Arial,sans-serif;margin:0;padding:0;width:100%;">
    <tr><td align="center">
      <table width="100%" cellpadding="0" cellspacing="0" style="font-family:Arial,sans-serif;margin:0;padding:0;width:100%;">
        <tr><td style="padding:25px 0;background-color:#0ea5e9;" align="center">
          <a href="{{product_url}}" style="color:#facc15;font-family:Arial,sans-serif;font-size:24px;font-weight:bold;text-decoration:none;">{{product_name}}</a>
        </td></tr>
        <tr><td bgcolor="#ffffff" style="border-top:1px solid #edeff2;border-bottom:1px solid #edeff2;">
          <table align="center" width="570" cellpadding="0" cellspacing="0" bgcolor="#ffffff" style="margin:0 auto;width:570px;">
            <tr><td style="padding:35px;">
              <h2 style="color:#f59e0b;font-size:22px;margin:0 0 10px;">🔍 Campaign Submitted for Review</h2>
              <p style="color:#74787e;font-size:14px;margin:0 0 20px;">An advertiser has submitted a campaign for approval. Please review it from the admin dashboard.</p>
              <div style="background-color:#f9fafb;padding:20px;border-radius:8px;margin-bottom:20px;">
                <table width="100%" cellpadding="0" cellspacing="0">
                  <tr><td style="padding:10px 0;border-bottom:1px solid #e5e7eb;">
                    <strong style="color:#0ea5e9;display:block;margin-bottom:4px;font-size:12px;text-transform:uppercase;">📣 Campaign Name</strong>
                    <p style="color:#1f2937;margin:0;font-size:15px;font-weight:600;">{{campaignName}}</p>
                  </td></tr>
                  <tr><td style="padding:10px 0;border-bottom:1px solid #e5e7eb;">
                    <strong style="color:#0ea5e9;display:block;margin-bottom:4px;font-size:12px;text-transform:uppercase;">📋 Type</strong>
                    <p style="color:#1f2937;margin:0;font-size:15px;">{{campaignType}}</p>
                  </td></tr>
                  <tr><td style="padding:10px 0;border-bottom:1px solid #e5e7eb;">
                    <strong style="color:#0ea5e9;display:block;margin-bottom:4px;font-size:12px;text-transform:uppercase;">🏢 Advertiser</strong>
                    <p style="color:#1f2937;margin:0;font-size:15px;">{{companyName}}</p>
                  </td></tr>
                  <tr><td style="padding:10px 0;border-bottom:1px solid #e5e7eb;">
                    <strong style="color:#0ea5e9;display:block;margin-bottom:4px;font-size:12px;text-transform:uppercase;">📧 Advertiser Email</strong>
                    <p style="color:#1f2937;margin:0;font-size:15px;">{{email}}</p>
                  </td></tr>
                  <tr><td style="padding:10px 0;border-bottom:1px solid #e5e7eb;">
                    <strong style="color:#0ea5e9;display:block;margin-bottom:4px;font-size:12px;text-transform:uppercase;">💰 Daily Budget</strong>
                    <p style="color:#1f2937;margin:0;font-size:15px;">¥{{dailyBudget}}</p>
                  </td></tr>
                  <tr><td style="padding:10px 0;">
                    <strong style="color:#0ea5e9;display:block;margin-bottom:4px;font-size:12px;text-transform:uppercase;">📅 Submitted At</strong>
                    <p style="color:#1f2937;margin:0;font-size:15px;">{{submittedAt}}</p>
                  </td></tr>
                </table>
              </div>
              <div style="text-align:center;">
                <a href="{{product_url}}/dashboard/ad-management" style="display:inline-block;padding:12px 28px;background-color:#facc15;color:#0369a1;text-decoration:none;border-radius:25px;font-weight:bold;font-size:15px;">Review Campaign</a>
              </div>
              <div style="margin-top:20px;padding:15px;background-color:#fffbeb;border-left:4px solid #f59e0b;border-radius:4px;">
                <p style="color:#92400e;margin:0;font-size:13px;"><strong>Action Required:</strong> Please review the campaign creatives and approve or reject it from the Ad Management dashboard.</p>
              </div>
            </td></tr>
          </table>
        </td></tr>
        <tr><td style="padding:20px;text-align:center;">
          <p style="color:#aeaeae;font-size:12px;margin:0;">{{product_name}} · {{company_address}}</p>
        </td></tr>
      </table>
    </td></tr>
  </table>
</body>
</html>
